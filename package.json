{
    "name": "bitsocial-telegram-bots",
    "version": "0.1.0",
    "description": "Telegram feed bots for Bitsocial clients (5chan, Seedit, etc.)",
    "author": "bitsocialhq",
    "license": "GPL-2.0-only",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "test": "vitest run",
        "start": "npx tsx src/index.ts",
        "start:5chan-feed": "BOT_NAME=5chan-feed npx tsx src/index.ts",
        "build": "tsc",
        "dev": "npx tsx --watch src/index.ts",
        "prettier": "prettier src/**/*.{js,ts} --write"
    },
    "dependencies": {
        "@plebbit/plebbit-js": "https://github.com/plebbit/plebbit-js.git#692ec349f01aa6d8e939ff1d6d07315ab92e4099",
        "dotenv": "16.4.5",
        "fs": "0.0.1-security",
        "node-fetch": "3.3.2",
        "p-queue": "8.0.1",
        "telegraf": "4.16.3",
        "tslog": "4.9.2",
        "typescript": "5.3.3"
    },
    "devDependencies": {
        "@telegraf/types": "7.1.0",
        "@types/node": "20.11.24",
        "prettier": "3.5.3",
        "tsx": "4.7.1",
        "vitest": "^4.0.18"
    },
    "resolutions": {
        "skia-canvas": "2.0.2"
    }
}
